    "signal": 8,
    "return-type": "json"
  },
  "custom/appmenu": {
    "on-click-right": "~/.local/bin/hyprland-launch-keybinds",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
    "on-click": "hyprlauncher",
    "format": "Apps"
  },
  "custom/pacman": {
    "format": "¾░Åö {}",
    "return-type": "json",
    "exec": "count=$(checkupdates 2>/dev/null | wc -l); if [ \"$count\" -gt 0 ]; then echo '{\"text\":\"'$count'\",\"tooltip\":\"'$count' updates available\"}'; else echo '{\"text\":\"\"}'; fi",
    "interval": 1800,
    "signal": 9,
    "on-click": "$HOME/.local/bin/hyprland-launch-updates"
  },
  "tray": {
